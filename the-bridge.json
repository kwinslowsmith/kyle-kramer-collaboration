  "data_pipeline": {
    "description": "How data flows between Viridian and KRAMOS",
    "inputs_from_viridian": [
      {
        "name": "Student Profile",
        "schema": {
          "student_id": "uuid",
          "name": "string",
          "domain": "string (improv | us_history_2_1 | lhum400)",
          "interests": ["string"],
          "reading_level": "string (5th-grade | 7th-grade | college)",
          "prior_mastery": {
            "standard_id": "string",
            "level": "string (Approaching | Developing | Proficient)"
          }
        },
        "example": {
          "student_id": "uuid-123",
          "name": "Alex Chen",
          "domain": "us_history_2_1",
          "interests": ["Civil War", "narrative-driven history"],
          "reading_level": "college",
          "prior_mastery": [
            { "standard_id": "2.1-a", "level": "Developing" }
          ]
        }
      },
      {
        "name": "Standard Definition",
        "schema": {
          "domain": "string",
          "standard_id": "string",
          "title": "string",
          "description": "string",
          "objectives": [
            {
              "code": "string (A, B, C...)",
              "description": "string"
            }
          ]
        }
      }
    ],
    "outputs_from_kramos": [
      {
        "name": "Generated Packet",
        "schema": {
          "packet_id": "uuid",
          "student_id": "uuid",
          "standard_id": "string",
          "domain": "string",
          "generated_iso": "timestamp",
          "content": {
            "title": "string",
            "reading_level": "string",
            "pages": 2,
            "sections": ["intro", "main-content", "vocab-box", "comprehension-questions"],
            "sources": [
              {
                "author": "string",
                "title": "string",
                "url": "string"
              }
            ]
          }
        }
      },
      {
        "name": "Mastery Result",
        "schema": {
          "student_id": "uuid",
          "standard_id": "string",
          "packet_id": "uuid",
          "student_score": "number (0-100)",
          "time_to_completion": "number (minutes)",
          "notes": "string",
          "returned_iso": "timestamp"
        }
      }
    ]
  },
